name: Build and Release

on:
  push:
    tags:
      - 'v*'
  workflow_dispatch:

jobs:
  build-windows:
    runs-on: windows-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v6
      
      - name: Set up Python
        uses: actions/setup-python@v6
        with:
          python-version: '3.11'
      
      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt
          pip install pyinstaller
      
      - name: Build with PyInstaller
        run: |
          pyinstaller build.spec
      
      - name: List dist contents
        run: |
          dir dist
      
      - name: Create ZIP archive
        run: |
          Compress-Archive -Path dist\ClipCatcher\* -DestinationPath ClipCatcher-Windows.zip
      
      - name: Upload artifact
        uses: actions/upload-artifact@v7
        with:
          name: ClipCatcher-Windows
          path: ClipCatcher-Windows.zip

  build-macos:
    runs-on: macos-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v6
      
      - name: Set up Python
        uses: actions/setup-python@v6
        with:
          python-version: '3.11'
      
      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt
          pip install pyinstaller
      
      - name: Build with PyInstaller
        run: |
          pyinstaller build.spec
      
      - name: List dist contents
        run: |
          ls -la dist/
      
      - name: Create ZIP (skip DMG for now)
        run: |
          cd dist
          zip -r ../ClipCatcher-macOS.zip ClipCatcher.app
      
      - name: Upload artifact
        uses: actions/upload-artifact@v7
        with:
          name: ClipCatcher-macOS
          path: ClipCatcher-macOS.zip

  release:
    needs: [build-windows, build-macos]
    runs-on: ubuntu-latest
    if: startsWith(github.ref, 'refs/tags/')
    steps:
      - name: Download Windows artifact
        uses: actions/download-artifact@v8
        with:
          name: ClipCatcher-Windows
      
      - name: Download macOS artifact
        uses: actions/download-artifact@v8
        with:
          name: ClipCatcher-macOS
      
      - name: Create Release
        uses: softprops/action-gh-release@v2
        with:
          files: |
            ClipCatcher-Windows.zip
            ClipCatcher-macOS.zip
          draft: false
          prerelease: false
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
